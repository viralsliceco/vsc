# =========================================================================
# Viral Slice Co — apps/www environment variables
# Copy to .env.local for local dev, set the same values in Vercel project
# settings for production.
# =========================================================================

# ---- Meta (Facebook) Pixel ----------------------------------------------
# Client-side pixel (must be NEXT_PUBLIC_ to ship to the browser).
NEXT_PUBLIC_META_PIXEL_ID=1733096037992385

# Server-side Conversions API. Same pixel ID + a System User token from
# Meta Business Manager > Settings > System Users > Generate Token.
# Required scopes: ads_management
META_PIXEL_ID=1733096037992385
META_CAPI_TOKEN=

# ---- Lead delivery: Resend (transactional email) ------------------------
# https://resend.com — create an API key. Free tier is plenty to start.
RESEND_API_KEY=
# Address that lead alerts are sent TO (internal inbox).
LEAD_NOTIFICATION_EMAIL=james@viralsliceco.com
# Address lead alerts are sent FROM. Must be on a domain you've verified
# in Resend, otherwise leave the default sandbox sender for testing.
LEAD_FROM_EMAIL="Viral Slice Leads <onboarding@resend.dev>"

# ---- Lead delivery: Google Sheets (via Apps Script) ---------------------
# Paste the web-app URL from your Apps Script deployment (see SETUP.md).
SHEETS_WEBHOOK_URL=

# ---- Booking ------------------------------------------------------------
# Google Calendar Appointment Scheduling URL (see SETUP.md).
NEXT_PUBLIC_BOOKING_URL=

# ---- Existing -----------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
SITE_URL=https://viralsliceco.com
