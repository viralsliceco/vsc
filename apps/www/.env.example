# =========================================================================
# Viral Slice Co — apps/www environment variables
# Copy to .env.local for local dev, set the same values in Vercel project
# settings for production.
# =========================================================================

# ---- Meta (Facebook) Pixel ----------------------------------------------
# Client-side pixel (must be NEXT_PUBLIC_ to ship to the browser).
NEXT_PUBLIC_META_PIXEL_ID=1733096037992385

# Server-side Conversions API token. Generate it in Meta Events Manager:
# select your pixel > Settings > Conversions API > Generate access token.
# This is the only Meta secret that genuinely needs to be private.
META_CAPI_TOKEN=

# Optional: META_PIXEL_ID. The CAPI code falls back to NEXT_PUBLIC_META_PIXEL_ID
# above, so you normally do NOT need to set this. Only set it if you want CAPI
# to post to a different pixel than the client-side one.
# META_PIXEL_ID=

# Optional: META_TEST_EVENT_CODE. Set this to a code from Events Manager >
# Test Events to make server CAPI events appear in the Test Events tab for
# verification. UNSET it in production — otherwise real conversions get
# routed to test data and won't count toward ad optimization.
# META_TEST_EVENT_CODE=

# ---- Lead delivery: Resend (transactional email) ------------------------
# https://resend.com — create an API key. Free tier is plenty to start.
RESEND_API_KEY=
# Address that lead alerts are sent TO (internal inbox).
LEAD_NOTIFICATION_EMAIL=james@viralsliceco.com
# Address lead alerts are sent FROM. Must be on a domain you've verified
# in Resend, otherwise leave the default sandbox sender for testing.
LEAD_FROM_EMAIL="Viral Slice Leads <onboarding@resend.dev>"

# ---- Lead delivery: Google Sheets (via Apps Script) ---------------------
# Paste the web-app URL from your Apps Script deployment (see SETUP.md).
SHEETS_WEBHOOK_URL=

# ---- Booking ------------------------------------------------------------
# Google Calendar Appointment Scheduling URL (see SETUP.md).
NEXT_PUBLIC_BOOKING_URL=

# ---- Google Analytics 4 -------------------------------------------------
# https://analytics.google.com → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-RLFMTZ5NC3

# ---- Existing -----------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
SITE_URL=https://viralsliceco.com
